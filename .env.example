# Gas Town Starter Kit — environment template
#
# Copy this file to `.env` and fill in the values. The wizard
# (`./wizard/gt-wizard init`) writes this for you, so you usually
# don't need to edit it by hand.
#
# NEVER commit `.env`. It's in `.gitignore`.

# --- Claude auth -----------------------------------------------------------
#
# Preferred: leave ANTHROPIC_API_KEY empty and rely on `claude login` on the
# host. The installer mounts your host's ~/.claude/ into the container so the
# Claude session inside Docker reuses your subscription auth.
#
# Only set ANTHROPIC_API_KEY if you intend to use per-token billing and do not
# have a Claude Pro / Max subscription. If set, it takes precedence.
ANTHROPIC_API_KEY=

# --- Telegram bots ---------------------------------------------------------
#
# Separate bots for separate concerns. Create each with @BotFather on Telegram.
# Format: "123456789:AAaaBBbbCCccDDddEEeeFFffGGggHHhhIIii"
#
#   GT_BOT_TOKEN      — gt-bot: Gas Town's default bridge (status + ops).
#                       Shipped with gasdepot; starts automatically on
#                       container boot. Skipped if empty.
#   GT_BOT_TOKEN_DEV  — gt-bot for the dev/staging container, ONLY used
#                       by `docker compose -f docker-compose.dev.yml up`.
#                       Create a SECOND bot via @BotFather (e.g. gasDepotDev)
#                       so prod and dev don't fight over the same Telegram
#                       webhook. Leave empty if you don't run a dev container.
#                       See docs/dev-environment.md for the full flow.
#   TELETALK_BOT_TOKEN — teletalk: conversational relay (optional).
#   CROW_BOT_TOKEN    — crow: legacy bridge, coexists with gt-bot (optional).
GT_BOT_TOKEN=
GT_BOT_TOKEN_DEV=
TELETALK_BOT_TOKEN=
CROW_BOT_TOKEN=

# Your own Telegram user ID — Mayor will DM you here for escalations and the
# bots will only accept messages from allow-listed chat IDs. Find yours by
# messaging @userinfobot on Telegram.
OPERATOR_TELEGRAM_CHAT_ID=

# --- Runtime ---------------------------------------------------------------
#
# Internal container defaults. You rarely need to change these.
GASTOWN_HOME=/gastown
# Dolt SQL server port. Bump to e.g. 3308 if the host already runs a
# Dolt instance on 3307 (gt dolt status). The entrypoint mirrors this
# value into GT_DOLT_PORT so gt-bot's mysql2 client uses the same port.
DOLT_PORT=3307
LOG_LEVEL=info
# GT_TOWN_ROOT tells gt (and gt-bot) where the HQ lives. The entrypoint
# also exports this, but shipping it in .env means subprocesses spawned
# via docker-compose env_file see it too. The HQ lives inside
# /gastown/repos so it persists via the gastown-repos named volume.
GT_TOWN_ROOT=/gastown/repos/hq

# --- User metadata ---------------------------------------------------------
#
# Used for git commits authored by agents working in your container. Defaults
# are filled in from `git config --global` at install time.
GIT_USER_NAME=
GIT_USER_EMAIL=

# --- Optional features -----------------------------------------------------
#
# rigs-dashboard: read-only status webpage at http://localhost:3338. Opt in
# at `docker compose --profile dashboard up -d`. Set DASHBOARD_AUTH_TOKEN to
# require ?token=… on every request (recommended if you port-forward it).
DASHBOARD_AUTH_TOKEN=
# Set COMPOSE_PROFILES=dashboard to make `docker compose up -d` (no flags)
# bring the dashboard up. Multiple profiles are comma-separated.
# COMPOSE_PROFILES=dashboard
