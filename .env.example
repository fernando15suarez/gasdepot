# Gas Town Starter Kit — environment template
#
# Copy this file to `.env` and fill in the values. The wizard
# (`./wizard/gt-wizard init`) writes this for you, so you usually
# don't need to edit it by hand.
#
# NEVER commit `.env`. It's in `.gitignore`.

# --- Claude auth -----------------------------------------------------------
#
# Preferred: leave ANTHROPIC_API_KEY empty and rely on `claude login` on the
# host. The installer mounts your host's ~/.claude/ into the container so the
# Claude session inside Docker reuses your subscription auth.
#
# Only set ANTHROPIC_API_KEY if you intend to use per-token billing and do not
# have a Claude Pro / Max subscription. If set, it takes precedence.
ANTHROPIC_API_KEY=

# --- Telegram bots ---------------------------------------------------------
#
# Separate bots for separate concerns. Create each with @BotFather on Telegram.
# Format: "123456789:AAaaBBbbCCccDDddEEeeFFffGGggHHhhIIii"
#
#   GT_BOT_TOKEN      — gt-bot: Gas Town's default bridge (status + ops).
#                       Shipped with gasdepot; starts automatically on
#                       container boot. Skipped if empty.
#   TELETALK_BOT_TOKEN — teletalk: conversational relay (optional).
#   CROW_BOT_TOKEN    — crow: legacy bridge, coexists with gt-bot (optional).
GT_BOT_TOKEN=
TELETALK_BOT_TOKEN=
CROW_BOT_TOKEN=

# Your own Telegram user ID — Mayor will DM you here for escalations and the
# bots will only accept messages from allow-listed chat IDs. Find yours by
# messaging @userinfobot on Telegram.
OPERATOR_TELEGRAM_CHAT_ID=

# --- Runtime ---------------------------------------------------------------
#
# Internal container defaults. You rarely need to change these.
GASTOWN_HOME=/gastown
DOLT_PORT=3307
LOG_LEVEL=info

# --- User metadata ---------------------------------------------------------
#
# Used for git commits authored by agents working in your container. Defaults
# are filled in from `git config --global` at install time.
GIT_USER_NAME=
GIT_USER_EMAIL=
