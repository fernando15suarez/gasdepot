#!/usr/bin/env bash
# Fake `gt` used by the bot's tests. Records every invocation (argv +
# stdin if passed) to $GT_FAKE_LOG, then exits 0. Never touches Dolt, mail,
# or any real Gas Town state.
#
# Stdin bodies can be multi-line (mail bodies usually are), so we wrap
# them in STDIN_BEGIN / STDIN_END markers and the helper reassembles.
set -euo pipefail

LOG="${GT_FAKE_LOG:-/dev/null}"
{
  printf 'ARGV\t'
  printf '%s\t' "$@"
  printf '\n'
} >>"$LOG"

# --help calls used for gtAvailable() probing don't get stdin. Skip.
for a in "$@"; do
  if [[ "$a" == "--stdin" ]]; then
    {
      printf 'STDIN_BEGIN\n'
      cat
      printf '\nSTDIN_END\n'
    } >>"$LOG"
    break
  fi
done

exit 0
