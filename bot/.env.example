# gt-bot environment file
# Copy to .env and fill in values. The .env file must never be committed.

# Required — Telegram bot token from BotFather
TELEGRAM_BOT_TOKEN=

# Optional — HTTP API port (default 3335; crow uses 3333, teletalk uses 3334)
GT_BOT_PORT=3335

# Optional — Dolt server port (default 3307)
GT_DOLT_PORT=3307
